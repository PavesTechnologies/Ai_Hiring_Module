# ── Database (Aiven PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://avnadmin:<PASSWORD>@<HOST>.aivencloud.com:<PORT>/defaultdb?sslmode=require
DB_SSL_CA_PATH=./certs/ca.pem          # path to downloaded Aiven CA certificate

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (MinIO / AWS S3) ───────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes
AWS_S3_BUCKET=                         # leave blank if using MinIO

# ── AI / Embeddings ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Encryption (PII / Fernet) ─────────────────────────────────────────────────
CANDIDATE_PII_KEY=                     # Fernet key — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
DEBUG=true
